@startuml activity
skinparam defaultTextAlignment center
skinparam swimlaneWidth 270
skinparam wrapWidth 270
title Процесс создания страховки для кредитного продукта

|Frontend|
start
:POST /api/v1/insurances;
|API Gateway|
:GET /health;
note right: проверка доступности сервисов;
if (Сервис страхования и сервис оплаты и Bank API недоступны?) then (да)
  |API Gateway|
  :HTTP 429 - Сервис недоступен;
  |Frontend|
  :Показать ошибку пользователю;
  stop
endif
|API Gateway|
:POST /api/v1/insurances;
|Insurance Service|
:GET /api/v1/requests/{request_id};
|Kafka|
:Передача данных о наличии \nсобытия создания страхования;
|Insurance Service|
if (Идемпотентность не подтверждена?) then (да)
  |API Gateway|
  :HTTP 409 (конфликт);
  |Frontend|
  :Показать ошибку пользователю;
  stop
endif
|Insurance Service|
:GET /api/v1/authorization_events/{event_id};
|Kafka|
:Событие авторизации;
|Insurance Service|
if (Пользователь не авторизован?) then (да)
  |API Gateway|
  :HTTP 401;
  |Frontend|
  :Показать ошибку пользователю;
  stop
endif
|Insurance Service|
:GET /api/v1/users/{user_id};
|Database|
:Проверка прав пользователя;
|Insurance Service|
if (Права отсутствуют?) then (да)
  |API Gateway|
  :HTTP 403;
  |Frontend|
  :Показать ошибку пользователю;
  stop
endif
|Insurance Service|
:GET /bankapi/v1/credit_products/{credit_product_id};
|BankAPI|
:Передача информации о существовании;
|Insurance Service|
if (Кредитный продукт не существует?) then (да)
  |API Gateway|
  :HTTP 404;
  |Frontend|
  :Показать ошибку пользователю;
  stop
endif
|Insurance Service|
:GET /bankapi/v1/loan_products/credit_rate;
|BankAPI|
:Вернуть текущую ставку;
|Insurance Service|
:Рассчитать новую ставку со страховкой;
:Сформировать предложение (инверсный вариант);
|API Gateway|
:Передать предложение во Frontend;
|Frontend|
:Показать пользователю предложение;
|API Gateway|
:Передать выбор в Insurance Service;
|Insurance Service|
if (Клиент соглашается на инверсный вариант?) then (да)
  :Создать финальную форму для заполнения;
  :POST api/v1/payments;
  |Payment Service|
  :Выставить и принять оплату;
  |Insurance Service|
  :Оформить страхование;
  :POST /api/v1/insurances;
  |Database|
  :Запись данных о страховании;
  |Insurance Service|
  fork
    |API Gateway|
    :HTTP 201;
    |Frontend|
    :Показать результат пользователю;
  fork again
    |Insurance Service|
    :POST /api/v1/requests/{request_id};
    |Kafka|
    :Событие опубликовано;
  end fork
  stop
else (нет)
  |Insurance Service|
  :GET /bankapi/v1/loanagreements/risk-weights;
  |BankAPI|
  :Передать коэффициент в Insurance Service;
  |Insurance Service|
  :Сформировать набор доступных предложений;
endif
|Insurance Service|
:Собрать все варианты в \nединую форму предложения (Offer);
|API Gateway|
:Передать предложение во Frontend;
|Frontend|
:Показать пользователю варианты\n с ценами и условиями;
|API Gateway|
:Передать выбор в Insurance Service;
|Insurance Service|
if (Выбран вариант с повышенным риском?) then (да)
  :POST /api/v1/consents;
  |API Gateway|
  :Передать запрос во Frontend;
  |Frontend|
  :Показать пользователю запрос на усиленное согласие;
  |API Gateway|
  :Передать подтверждение в Insurance Service;
endif
|Insurance Service|
:Создать финальную форму для заполнения\n (на основе выбранного варианта);
:POST api/v1/payments;
|Payment Service|
:Выставить и принять оплату;
|Insurance Service|
:Оформить страхование кредитного продукта;
:POST /api/v1/insurances;
|Database|
:Запись данных о страховании;
|Insurance Service|
fork
  :Сформировать успешный ответ;
  |API Gateway|
  :Передать результат во Frontend;
  |Frontend|
  :Показать результат пользователю;
fork again
  :POST /api/v1/events/{event_id};
  |Kafka|
  :Событие опубликовано;
end fork
stop
