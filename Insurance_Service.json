{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Insurance Service",
  "description": "Схема для представления кредитного продукта",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/credit_product"
    },
    {
      "$ref": "#/$defs/insurance_contract"
    },
    {
      "$ref": "#/$defs/borrower"
    },
    {
      "$ref": "#/$defs/payment"
    }
  ],
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "href",
        "method",
        "rel"
      ],
      "properties": {
        "href": {
          "type": "string",
          "format": "uri"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PATCH",
            "DELETE"
          ]
        },
        "rel": {
          "type": "string",
          "enum": [
            "self",
            "credit_product",
            "credit_products",
            "insurance_contract",
            "insurance_contracts",
            "borrower",
            "borrowers",
            "payment",
            "payments"
          ]
        }
      }
    },
    "links": {
      "type": "array",
      "description": "Список доступных операций",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "credit_product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credit_product_id",
        "product_name",
        "product_type",
        "credit_product_status",
        "loan_amount",
        "current_loan_amount",
        "loan_length",
        "interest_rate",
        "payment_frequency",
        "insure_status",
        "borrow_id",
        "loan_created_at"
      ],
      "properties": {
        "credit_product_id": {
          "type": "string",
          "format": "uuid"
        },
        "product_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "product_type": {
          "type": "string",
          "enum": [
            "Кредит физическим лицам",
            "Кредит юридическим лицам",
            "Межбанковский кредит",
            "Государственный кредит"
          ]
        },
        "credit_product_status": {
          "type": "string",
          "enum": [
            "активный",
            "архивный"
          ]
        },
        "loan_amount": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000000000,
          "multipleOf": 0.01
        },
        "current_loan_amount": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000000000,
          "multipleOf": 0.01
        },
        "loan_length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "interest_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "payment_frequency": {
          "type": "string",
          "enum": [
            "ежемесячно",
            "ежегодно"
          ]
        },
        "insure_status": {
          "type": "string",
          "enum": [
            "нет страховки",
            "есть страховка"
          ]
        },
        "borrow_id": {
          "type": "string",
          "format": "uuid"
        },
        "loan_created_at": {
          "type": "string",
          "format": "date-time"
        },
        "_links": {
          "$ref": "#/$defs/links"
        }
      }
    },
    "insurance_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "credit_product_id",
        "borrow_id",
        "insurance_type",
        "insurance_level",
        "insurance_details",
        "payment_status",
        "_links"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "format": "uuid"
        },
        "credit_product_id": {
          "type": "string",
          "format": "uuid"
        },
        "borrow_id": {
          "type": "string",
          "format": "uuid"
        },
        "insurance_type": {
          "type": "string",
          "enum": [
            "инвестиционное страхование",
            "страхование с залогом"
          ]
        },
        "insurance_level": {
          "type": "string",
          "enum": [
            "полное страхование",
            "базовое страхование"
          ]
        },
        "insurance_details": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "payment_status": {
          "type": "string",
          "enum": [
            "pending",
            "processing",
            "completed",
            "failed"
          ]
        },
        "_links": {
          "$ref": "#/$defs/links"
        }
      }
    },
    "borrower": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "borrow_id",
        "age",
        "monthly_income",
        "employment_status",
        "_links"
      ],
      "properties": {
        "borrow_id": {
          "type": "string",
          "format": "uuid"
        },
        "age": {
          "type": "integer",
          "minimum": 18,
          "maximum": 100
        },
        "monthly_income": {
          "type": "number",
          "minimum": 0,
          "maximum": 100000000
        },
        "employment_status": {
          "type": "string",
          "enum": [
            "трудоустроен",
            "самозанятый",
            "безработный"
          ]
        },
        "_links": {
          "$ref": "#/$defs/links"
        }
      }
    },
    "payment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payment_id",
        "insurance_contract_id",
        "payment_details",
        "payment_sum",
        "currency",
        "paid_at",
        "_links"
      ],
      "properties": {
        "payment_id": {
          "type": "string",
          "format": "uuid"
        },
        "insurance_contract_id": {
          "type": "string",
          "format": "uuid"
        },
        "payment_details": {
          "type": "string",
          "minLength": 12,
          "maxLength": 12
        },
        "payment_sum": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000000
        },
        "currency": {
          "type": "string",
          "enum": [
            "RUB",
            "EUR",
            "USD"
          ]
        },
        "paid_at": {
          "type": "string",
          "format": "date-time"
        },
        "_links": {
          "$ref": "#/$defs/links"
        }
      }
    }
  }
}